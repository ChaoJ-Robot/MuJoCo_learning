<mujoco model="first_model">
    <compiler angle="degree" autolimits="true"/>
    <option timestep="0.002" gravity="0 0 -9.81"/>

    <default>
        <geom rgba="0.7 0.7 0.7 1" contype="1" conaffinity="1"/>
        <joint damping="1"/>
    </default>

    <worldbody>
        <!-- 地面 -->
        <geom name="ground" type="plane" size="5 5 0.1" pos="0 0 0"
              rgba="1 1 1 1"/>

        <!-- 基座 -->
        <body name="base" pos="0 0 0.1">
            <geom name="base_geom" type="box" size="0.05 0.05 0.05"
                  rgba="0.8 0.2 0.2 1"/>

            <!-- 摆杆 -->
            <body name="link1" pos="0 0 0.05">
                <joint name="hinge1" type="hinge" axis="0 1 0" range="-90 90"/>
                <geom name="link1_geom" type="capsule" fromto="0 0 0 0 0 0.4"
                      size="0.03" rgba="0.2 0.6 0.8 1"/>
            

                <body name="link2" pos="0 0 0.4">
                    <joint name="hinge2" type="hinge" axis="0 1 0" range="-90 90"/>
                    <geom name="link2_geom" type="capsule" fromto="0 0 0 0 0 0.4"
                        size="0.03" rgba="0.6 0.6 0.8 1"/>
                </body>

            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="m1" joint="hinge1" ctrlrange="-1 1" gear="50"/>
        <motor name="m2" joint="hinge2" ctrlrange="-1 1" gear="50"/>
    </actuator>
</mujoco>
<mujoco model="gen3_gripper_d435i_real">
  <compiler angle="radian" meshdir="assets"/>

  <option integrator="implicitfast"/>

  <default>
    <default class="visual">
      <geom type="mesh" contype="0" conaffinity="0" group="2" rgba="0.75294 0.75294 0.75294 1"/>
    </default>

    <default class="collision">
      <geom type="mesh" group="3"/>
    </default>

    <default class="large_actuator">
      <position kp="2000" kv="100" forcerange="-105 105"/>
    </default>

    <default class="small_actuator">
      <position kp="500" kv="50" forcerange="-52 52"/>
    </default>

    <default class="gripper_actuator">
      <position kp="1200" kv="80" forcerange="-80 80"/>
    </default>

    <!-- D435i 专用默认参数，来自开源模型并稍作整合 -->
    <default class="d435i">
      <material specular="0" shininess="0.25"/>
      <default class="d435i_visual">
        <geom group="2" type="mesh" contype="0" conaffinity="0" mass="0"/>
      </default>
      <default class="d435i_collision">
        <geom group="3" type="mesh" mass="0"/>
      </default>
    </default>

    <site size="0.001" rgba="0.5 0.5 0.5 0.3" group="4"/>
  </default>

  <asset>
    <!-- 原机械臂 mesh -->
    <mesh name="base_link" file="base_link.stl"/>
    <mesh name="shoulder_link" file="shoulder_link.stl"/>
    <mesh name="half_arm_1_link" file="half_arm_1_link.stl"/>
    <mesh name="half_arm_2_link" file="half_arm_2_link.stl"/>
    <mesh name="forearm_link" file="forearm_link.stl"/>
    <mesh name="spherical_wrist_1_link" file="spherical_wrist_1_link.stl"/>
    <mesh name="spherical_wrist_2_link" file="spherical_wrist_2_link.stl"/>
    <mesh name="bracelet_with_vision_link" file="bracelet_with_vision_link.stl"/>

    <!-- D435i 材质：来自你上传的开源 d435i.xml -->
    <material class="d435i" name="Black_Acrylic" rgba="0.070360 0.070360 0.070360 1"/>
    <material class="d435i" name="Cameras_Gray" rgba="0.296138 0.296138 0.296138 1"/>
    <material class="d435i" name="IR_Emitter_Lens" rgba="0.287440 0.665387 0.327778 1"/>
    <material class="d435i" name="IR_Lens" rgba="0.035601 0.035601 0.035601 1"/>
    <material class="d435i" name="IR_Rim" rgba="0.799102 0.806952 0.799103 1"/>
    <material class="d435i" name="Metal_Casing" rgba="1 1 1 1"/>
    <material class="d435i" name="RGB_Pupil" rgba="0.087140 0.002866 0.009346 1"/>

    <!--
      重要：下面 9 个 OBJ 文件，默认假设你已经把它们复制到“机械臂主 XML 所在目录的 assets/”里。
      也就是和 base_link.stl 等放在同一个 assets 文件夹内。
    -->
    <mesh name="d435i_0" file="d435i_0.obj"/>
    <mesh name="d435i_1" file="d435i_1.obj"/>
    <mesh name="d435i_2" file="d435i_2.obj"/>
    <mesh name="d435i_3" file="d435i_3.obj"/>
    <mesh name="d435i_4" file="d435i_4.obj"/>
    <mesh name="d435i_5" file="d435i_5.obj"/>
    <mesh name="d435i_6" file="d435i_6.obj"/>
    <mesh name="d435i_7" file="d435i_7.obj"/>
    <mesh name="d435i_8" file="d435i_8.obj"/>
  </asset>

  <worldbody>
    <body name="base_link">
      <inertial pos="-0.000648 -0.000166 0.084487"
                quat="0.999294 0.00139618 -0.0118387 0.035636"
                mass="1.697"
                diaginertia="0.00462407 0.00449437 0.00207755"/>
      <geom class="visual" mesh="base_link"/>
      <geom class="collision" mesh="base_link"/>

      <body name="shoulder_link" pos="0 0 0.15643" quat="0 1 0 0">
        <inertial pos="-2.3e-05 -0.010364 -0.07336"
                  quat="0.707051 0.0451246 -0.0453544 0.704263"
                  mass="1.3773"
                  diaginertia="0.00488868 0.00457 0.00135132"/>
        <joint name="joint_1"/>
        <geom class="visual" mesh="shoulder_link"/>
        <geom class="collision" mesh="shoulder_link"/>

        <body name="half_arm_1_link" pos="0 0.005375 -0.12838" quat="1 1 0 0">
          <inertial pos="-4.4e-05 -0.09958 -0.013278"
                    quat="0.482348 0.516286 -0.516862 0.483366"
                    mass="1.1636"
                    diaginertia="0.0113017 0.011088 0.00102532"/>
          <joint name="joint_2" range="-2.24 2.24"/>
          <geom class="visual" mesh="half_arm_1_link"/>
          <geom class="collision" mesh="half_arm_1_link"/>

          <body name="half_arm_2_link" pos="0 -0.21038 -0.006375" quat="1 -1 0 0">
            <inertial pos="-4.4e-05 -0.006641 -0.117892"
                      quat="0.706144 0.0213722 -0.0209128 0.707437"
                      mass="1.1636"
                      diaginertia="0.0111633 0.010932 0.00100671"/>
            <joint name="joint_3"/>
            <geom class="visual" mesh="half_arm_2_link"/>
            <geom class="collision" mesh="half_arm_2_link"/>

            <body name="forearm_link" pos="0 0.006375 -0.21038" quat="1 1 0 0">
              <inertial pos="-1.8e-05 -0.075478 -0.015006"
                        quat="0.483678 0.515961 -0.515859 0.483455"
                        mass="0.9302"
                        diaginertia="0.00834839 0.008147 0.000598606"/>
              <joint name="joint_4" range="-2.57 2.57"/>
              <geom class="visual" mesh="forearm_link"/>
              <geom class="collision" mesh="forearm_link"/>

              <body name="spherical_wrist_1_link" pos="0 -0.20843 -0.006375" quat="1 -1 0 0">
                <inertial pos="1e-06 -0.009432 -0.063883"
                          quat="0.703558 0.0707492 -0.0707492 0.703558"
                          mass="0.6781"
                          diaginertia="0.00165901 0.001596 0.000346988"/>
                <joint name="joint_5"/>
                <geom class="visual" mesh="spherical_wrist_1_link"/>
                <geom class="collision" mesh="spherical_wrist_1_link"/>

                <body name="spherical_wrist_2_link" pos="0 0.00017505 -0.10593" quat="1 1 0 0">
                  <inertial pos="1e-06 -0.045483 -0.00965"
                            quat="0.44426 0.550121 -0.550121 0.44426"
                            mass="0.6781"
                            diaginertia="0.00170087 0.001641 0.00035013"/>
                  <joint name="joint_6" range="-2.09 2.09"/>
                  <geom class="visual" mesh="spherical_wrist_2_link"/>
                  <geom class="collision" mesh="spherical_wrist_2_link"/>

                  <body name="bracelet_link" pos="0 -0.10593 -0.00017505" quat="1 -1 0 0">
                    <inertial pos="0.000281 0.011402 -0.029798"
                              quat="0.394358 0.596779 -0.577293 0.393789"
                              mass="0.5"
                              diaginertia="0.000657336 0.000587019 0.000320645"/>
                    <joint name="joint_7"/>
                    <geom class="visual" mesh="bracelet_with_vision_link"/>
                    <geom class="collision" mesh="bracelet_with_vision_link"/>

                    <!-- 原模型自带腕部相机，建议保留，调试用 -->
                    <camera name="wrist"
                            pos="0 -0.05639 -0.058475"
                            quat="0 0 0 1"
                            fovy="41.83792730009236"
                            resolution="640 480"/>

                    <!-- 原 pinch site 保留 -->
                    <site name="pinch_site" pos="0 0 -0.061525" quat="0 1 0 0"/>

                    <!-- ========================= -->
                    <!-- 新增：平行夹爪基座 -->
                    <!-- ========================= -->
                    <body name="gripper_base" pos="0 0 -0.075" quat="1 0 0 0">
                      <inertial pos="0 0 0.03"
                                mass="0.35"
                                diaginertia="0.0006 0.0006 0.0004"/>

                      <geom name="gripper_base_geom"
                            type="box"
                            size="0.028 0.032 0.025"
                            pos="0 0 0.03"
                            rgba="0.25 0.25 0.25 1"/>

                      <site name="gripper_center" pos="0 0 0.11" size="0.004" rgba="0 1 0 1"/>
                      <site name="grasp_target_site" pos="0 0 0.145" size="0.005" rgba="1 0 0 1"/>

                      <!-- 左手指 -->
                      <body name="left_finger" pos="0 0.02 0.07">
                        <joint name="left_finger_joint"
                               type="slide"
                               axis="0 1 0"
                               range="0 0.018"
                               damping="8"/>

                        <inertial pos="0 0.01 0.03"
                                  mass="0.08"
                                  diaginertia="0.00008 0.00008 0.00003"/>

                        <geom name="left_finger_geom"
                              type="box"
                              size="0.008 0.004 0.045"
                              pos="0 0.008 0.03"
                              rgba="0.15 0.15 0.15 1"/>

                        <geom name="left_tip_geom"
                              type="box"
                              size="0.006 0.003 0.012"
                              pos="0 0.008 0.09"
                              rgba="0.35 0.35 0.35 1"/>
                      </body>

                      <!-- 右手指 -->
                      <body name="right_finger" pos="0 -0.02 0.07">
                        <joint name="right_finger_joint"
                               type="slide"
                               axis="0 -1 0"
                               range="0 0.018"
                               damping="8"/>

                        <inertial pos="0 -0.01 0.03"
                                  mass="0.08"
                                  diaginertia="0.00008 0.00008 0.00003"/>

                        <geom name="right_finger_geom"
                              type="box"
                              size="0.008 0.004 0.045"
                              pos="0 -0.008 0.03"
                              rgba="0.15 0.15 0.15 1"/>

                        <geom name="right_tip_geom"
                              type="box"
                              size="0.006 0.003 0.012"
                              pos="0 -0.008 0.09"
                              rgba="0.35 0.35 0.35 1"/>
                      </body>

                      <!-- ========================= -->
                      <!-- 新增：Eye-in-Hand D435i -->
                      <!-- ========================= -->
                      <body name="camera_mount" pos="0.04 0 0.11" euler="0 -0.60 0">
                        <inertial pos="0 0 0.015"
                                  mass="0.05"
                                  diaginertia="1e-05 1e-05 1e-05"/>

                        <geom name="camera_mount_geom"
                              type="box"
                              size="0.008 0.008 0.03"
                              pos="0 0 0.015"
                              rgba="0.2 0.2 0.2 1"/>

                        <!-- 真实 D435i 模型：由你上传的开源 d435i.xml 合并而来 -->
                        <body name="d435i" childclass="d435i" pos="0 0 0.05" quat="1 0 0 0">
                          <inertial pos="0 0 0"
                                    mass="0.072"
                                    diaginertia="2e-05 2e-05 2e-05"/>

                          <geom mesh="d435i_0" material="IR_Lens" class="d435i_visual"/>
                          <geom mesh="d435i_1" material="IR_Emitter_Lens" class="d435i_visual"/>
                          <geom mesh="d435i_2" material="IR_Rim" class="d435i_visual"/>
                          <geom mesh="d435i_3" material="IR_Lens" class="d435i_visual"/>
                          <geom mesh="d435i_4" material="Cameras_Gray" class="d435i_visual"/>
                          <geom mesh="d435i_5" material="Black_Acrylic" class="d435i_visual"/>
                          <geom mesh="d435i_6" material="Black_Acrylic" class="d435i_visual"/>
                          <geom mesh="d435i_7" material="RGB_Pupil" class="d435i_visual"/>
                          <geom mesh="d435i_8" material="Metal_Casing" class="d435i_visual"/>

                          <!-- 用原开源模型中的碰撞近似策略 -->
                          <geom class="d435i_collision" type="capsule" mesh="d435i_8"/>

                          <!-- 光学参考点 -->
                          <site name="camera_optical_center"
                                pos="0 0 0"
                                size="0.004"
                                rgba="0 0 1 1"/>
                          <site name="camera_forward_ref"
                                pos="0.03 0 0"
                                size="0.003"
                                rgba="0 1 1 1"/>

                          <!-- RGB / Depth 相机，使用同一机体姿态 -->
                          <camera name="d435i_rgb"
                                  pos="0 0 0"
                                  quat="0.7071068 0 -0.7071068 0"
                                  fovy="58"
                                  resolution="640 480"/>
                          <camera name="d435i_depth"
                                  pos="0 0 0"
                                  quat="0.7071068 0 -0.7071068 0"
                                  fovy="58"
                                  resolution="640 480"/>
                        </body>
                      </body>
                    </body>
                    <!-- ========== 末端扩展结束 ========== -->

                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <!-- 原机械臂 7 轴 -->
    <position class="large_actuator" name="joint_1" joint="joint_1"/>
    <position class="large_actuator" name="joint_2" joint="joint_2"
              ctrlrange="-2.2497294058206907 2.2497294058206907"/>
    <position class="large_actuator" name="joint_3" joint="joint_3"/>
    <position class="large_actuator" name="joint_4" joint="joint_4"
              ctrlrange="-2.5795966344476193 2.5795966344476193"/>
    <position class="small_actuator" name="joint_5" joint="joint_5"/>
    <position class="small_actuator" name="joint_6" joint="joint_6"
              ctrlrange="-2.0996310901491784 2.0996310901491784"/>
    <position class="small_actuator" name="joint_7" joint="joint_7"/>

    <!-- 新增夹爪 actuator -->
    <position class="gripper_actuator"
              name="left_finger_act"
              joint="left_finger_joint"
              ctrlrange="0 0.018"/>
    <position class="gripper_actuator"
              name="right_finger_act"
              joint="right_finger_joint"
              ctrlrange="0 0.018"/>
  </actuator>

  <keyframe>
    <key name="home"
         qpos="0 0.26179939 3.14159265 -2.26892803 0 0.95993109 1.57079633 0.008 0.008"
         ctrl="0 0.26179939 3.14159265 -2.26892803 0 0.95993109 1.57079633 0.008 0.008"/>

    <key name="retract"
         qpos="0 -0.34906585 3.14159265 -2.54818071 0 -0.87266463 1.57079633 0.018 0.018"
         ctrl="0 -0.34906585 3.14159265 -2.54818071 0 -0.87266463 1.57079633 0.018 0.018"/>

    <key name="grasp_closed"
         qpos="0 0.26179939 3.14159265 -2.26892803 0 0.95993109 1.57079633 0.002 0.002"
         ctrl="0 0.26179939 3.14159265 -2.26892803 0 0.95993109 1.57079633 0.002 0.002"/>
  </keyframe>
</mujoco>
